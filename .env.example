# Last.fm (server-side only — do not prefix with PUBLIC_)
LASTFM_API_KEY=
LASTFM_USER=michaelschultz

# SQLite database path (default: ./data/listening.db)
DATABASE_PATH=./data/listening.db

# Protects GET /api/cron/sync-listening
CRON_SECRET=

# Optional cron override (default: 0 7,11,14,17,21 * * *)
# 7am, 11am, 2pm, 5pm, 9pm
# SYNC_CRON=0 7,11,14,17,21 * * *

# Bluesky app password for `pnpm status` (not used by the web server)
BLUESKY_HANDLE=michaelschultz.com
BLUESKY_APP_PASSWORD=
